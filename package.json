{
  "name": "traqula-sparql-1-2-rewriter",
  "type": "module",
  "version": "0.0.0",
  "private": "true",
  "packageManager": "yarn@1.22.22",
  "description": "Query rewriting for a SPARQL 1.2 query on RDF 1.1 data ",
  "lsd:module": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jitsedesmet/2025-query-rewriting-1-2"
  },
  "bugs": {
    "url": "https://github.com/jitsedesmet/2025-query-rewriting-1-2/issues"
  },
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/lib/index.d.ts",
      "import": "./dist/esm/lib/index.js",
      "require": "./dist/cjs/lib/index.js"
    }
  },
  "main": "dist/esm/lib/index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/*/lib/**/*.d.ts",
    "dist/*/lib/**/*.js",
    "dist/*/lib/**/*.js.map"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "typings": "lib/index",
  "scripts": {
    "build": "yarn build:ts && yarn build:cjs",
    "build:ts": "node \"node_modules/typescript/bin/tsc\" -b",
    "build:cjs": "node \"node_modules/typescript/bin/tsc\" -b tsconfig.cjs.json",
    "clean": "git clean -dfx",
    "doc": "typedoc",
    "lint": "eslint . --cache",
    "postinstall": "yarn husky && yarn run build",
    "test": "vitest test --run"
  },
  "dependencies": {
    "@traqula/algebra-sparql-1-2": "^1.0.2",
    "@traqula/algebra-transformations-1-2": "^1.0.2",
    "@traqula/core": "^1.0.2",
    "@traqula/generator-sparql-1-2": "^1.0.2",
    "@traqula/parser-sparql-1-2": "^1.0.2",
    "@traqula/rules-sparql-1-2": "^1.0.2",
    "rdf-data-factory": "^2.0.2"
  },
  "devDependencies": {
    "@comunica/query-sparql-file": "^5.1.3",
    "@rdfjs/types": "^2.0.0",
    "@rubensworks/eslint-config": "^3.1.0",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "n3": "^2.0.1",
    "rdf-isomorphic": "^2.0.1",
    "rdf-string": "^2.0.1",
    "rdf-terms": "^2.0.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
