{
  "name": "@landmaes/shacl-rule-1-2-parser",
  "type": "module",
  "version": "1.0.4",
  "packageManager": "yarn@1.22.22",
  "description": "A Traqula-based parser for SHACL-RULE syntax",
  "lsd:module": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jitsedesmet/2025-query-rewriting-1-2"
  },
  "bugs": {
    "url": "https://github.com/jitsedesmet/2025-query-rewriting-1-2/issues"
  },
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/cjs/package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "yarn build:ts && yarn build:cjs",
    "build:ts": "tsc -b",
    "build:cjs": "tsc -b tsconfig.cjs.json",
    "clean": "git clean -dfx",
    "prepare": "husky || true",
    "prepublishOnly": "yarn run build",
    "lint": "eslint . --cache",
    "test": "vitest test --run"
  },
  "dependencies": {
    "@rdfjs/types": "^2.0.1",
    "@traqula/algebra-sparql-1-2": "^1.0.7",
    "@traqula/algebra-transformations-1-2": "^1.0.7",
    "@traqula/core": "^1.0.7",
    "@traqula/generator-sparql-1-2": "^1.0.7",
    "@traqula/parser-sparql-1-2": "^1.0.7",
    "@traqula/rules-sparql-1-2": "^1.0.7",
    "rdf-data-factory": "^2.0.2"
  },
  "devDependencies": {
    "@comunica/query-sparql-file": "^5.1.3",
    "@rubensworks/eslint-config": "^3.1.0",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "n3": "^2.0.1",
    "rdf-isomorphic": "^2.0.1",
    "rdf-string": "^2.0.1",
    "rdf-terms": "^2.0.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
